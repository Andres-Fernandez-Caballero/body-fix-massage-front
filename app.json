{
  "expo": {
    "name": "BodyFix",
    "slug": "bodyfix-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D64F4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bodyfix.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BodyFix usa tu ubicación para mostrarte los locales más cercanos.",
        "NSPhotoLibraryUsageDescription": "BodyFix necesita acceso a tu galería para cambiar tu foto de perfil.",
        "NSCameraUsageDescription": "BodyFix necesita acceso a la cámara para tomar una foto de perfil."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBE63bnKDa9-RVTbCj6hU1K3Z2-ZIwIURU"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D64F4"
      },
      "package": "com.bodyfix.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBE63bnKDa9-RVTbCj6hU1K3Z2-ZIwIURU"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BodyFix usa tu ubicación para mostrarte los locales más cercanos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BodyFix necesita acceso a tu galería para cambiar tu foto de perfil.",
          "cameraPermission": "BodyFix necesita acceso a la cámara para tomar una foto de perfil."
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "scheme": "bodyfix",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9ca1b51-0a14-4820-bf35-cabcdb689145"
      }
    }
  }
}
